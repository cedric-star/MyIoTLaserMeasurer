    {
        "id": "27c2f838e126175c",
        "type": "function",
        "z": "e53b1d02762b092d",
        "name": "function 1",
        "func": "// Prüfen, ob Daten angekommen sind\nif (msg.payload === undefined) {\n    return msg;\n}\n\n// Aufbereiten der Daten für InfluxDB\nmsg.payload = [\n    {\n        // Fields: Deine gemessenen Werte\n        pm1: parseFloat(msg.payload.PM1),\n        pm25: parseFloat(msg.payload.PM25),\n        pm10: parseFloat(msg.payload.PM10),\n        battery: parseFloat(msg.payload.Battery)  // Battery optional\n    },\n    {\n        // Tags: Beschreibende Metadaten\n        standort: \"zimmer\",\n        sensor: \"hm300x\"\n    }\n];\n\n// WICHTIG: Hier wird der Measurement-Name gesetzt\nmsg.measurement = \"luftqualitaet\";\n\n// Gib die Nachricht aus\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
